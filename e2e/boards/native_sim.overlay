&flash0 {
	partitions {
		astarte_partition: partition@100000 {
			label = "astarte";
			reg = <0x00100000 DT_SIZE_K(128)>;
		};
		edgehog_partition: partition@120000 {
			label = "edgehog";
			reg = <0x00120000 DT_SIZE_K(128)>;
		};
	};
};
